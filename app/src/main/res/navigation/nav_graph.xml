<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.zelda.botwapp.ui.HomeFragment"
        android:label="The Legend of Zelda Wiki"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_category"
            app:destination="@id/categoryFragment" />
    </fragment>

    <fragment
        android:id="@+id/categoryFragment"
        android:name="com.zelda.botwapp.ui.CategoryFragment"
        tools:layout="@layout/fragment_category">
        <argument
            android:name="categoryName"
            app:argType="string" />
        <action
            android:id="@+id/action_category_to_detail"
            app:destination="@id/detailFragment" />
    </fragment>

    <fragment
        android:id="@+id/detailFragment"
        android:name="com.zelda.botwapp.ui.DetailFragment"
        tools:layout="@layout/fragment_detail" >
        <argument
            android:name="entryId"
            app:argType="integer" />
    </fragment>

</navigation>